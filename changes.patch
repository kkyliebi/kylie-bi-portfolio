+.questionButton {
+  align-items: start;
+  background: transparent;
+  border: 0;
+  color: var(--color-text);
+  cursor: pointer;
+  display: grid;
+  gap: var(--space-5);
+  grid-template-columns: 4.5rem minmax(0, 1fr) minmax(10rem, 17rem);
+  padding: var(--space-6) 0;
+  text-align: left;
+  transition: color var(--motion-duration-fast) var(--motion-ease-standard);
+  width: 100%;
+}
+
+.questionButton:hover .questionText,
+.questionButton:focus-visible .questionText,
+.questionButton[aria-expanded='true'] .questionText {
+  color: var(--color-text);
+}
+
+.questionNumber,
+.category {
+  color: var(--color-text-muted);
+  font-size: var(--font-size-caption);
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+.questionNumber {
+  padding-block-start: 0.2em;
+}
+
+.questionText {
+  color: color-mix(in srgb, var(--color-text) 88%, var(--color-text-muted));
+  font-size: var(--font-size-heading);
+  line-height: 1.08;
+  max-width: 22em;
+  transition: color var(--motion-duration-fast) var(--motion-ease-standard);
+}
+
+.questionProject {
+  color: var(--color-text-muted);
+  line-height: var(--line-height-relaxed);
+  padding-block-start: 0.15em;
+}
+
+.questionDetails {
+  display: grid;
+  gap: var(--space-3);
+  margin-inline-start: 4.5rem;
+  max-width: var(--layout-readable);
+  padding-block: 0 var(--space-6);
+}
+
+.category {
+  margin-block-end: var(--space-1);
+}
+
+.aboutGrid {
+  display: grid;
+  gap: var(--space-6);
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+}
+
+.subsection {
+  border-top: 1px solid var(--color-border);
+  display: grid;
+  gap: var(--space-3);
+  padding-block-start: var(--space-4);
+}
+
+.subsection h3 {
+  font-size: var(--font-size-body);
+  margin: 0;
+}
+
+.methodology {
+  color: var(--color-text-muted);
+  display: grid;
+  gap: var(--space-2);
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.methodology li {
+  align-items: center;
+  display: grid;
+  gap: var(--space-2);
+}
+
+.methodology li:not(:last-child)::after {
+  color: var(--color-text-muted);
+  content: '↓';
+}
+
+.downloadList {
+  display: grid;
+  gap: var(--space-3);
+  max-width: var(--layout-readable);
+}
+
+.downloadPlaceholder {
+  background: transparent;
+  border: 1px solid var(--color-border);
+  color: var(--color-text-muted);
+  padding: var(--space-4) var(--space-5);
+  text-align: left;
+}
+
+.contactLinks {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--space-4);
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+@media (max-width: 900px) {
+  .home {
+    gap: var(--space-9);
+  }
+
+  .aboutGrid {
+    grid-template-columns: 1fr;
+  }
+
+  .questionButton {
+    grid-template-columns: 3rem minmax(0, 1fr);
+  }
+
+  .questionProject {
+    grid-column: 2;
+  }
+
+  .questionDetails {
+    margin-inline-start: 3rem;
+  }
+}
+
+@media (max-width: 560px) {
+  .home {
+    gap: var(--space-8);
+  }
+
+  .section + .section {
+    padding-block-start: var(--space-6);
+  }
+
+  .questionButton {
+    gap: var(--space-3);
+    grid-template-columns: 1fr;
+    padding: var(--space-5) 0;
+  }
+
+  .questionProject,
+  .questionDetails {
+    grid-column: auto;
+    margin-inline-start: 0;
+  }
+}
